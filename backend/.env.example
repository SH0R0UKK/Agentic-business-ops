# Environment Variables for Agentic Business Ops Backend

# =============================================================================
# REQUIRED - Perplexity API
# =============================================================================
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PPLX_API_KEY=your_perplexity_api_key_here  # Alternative name

# =============================================================================
# OPTIONAL - LangSmith Tracing
# =============================================================================
# Uncomment to enable LangSmith tracing (completely optional)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=agentic-business-ops
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# OPTIONAL - Server Configuration
# =============================================================================
BACKEND_PORT=8000

# =============================================================================
# OPTIONAL - MLflow (DEPRECATED - no longer used)
# =============================================================================
# These are no longer needed but kept here for reference
# MLFLOW_TRACKING_URI=file:./mlruns

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file to .env in the same directory
# 2. Fill in your actual API keys
# 3. Never commit .env file to version control
# 4. LangSmith tracing is completely optional - the system works without it
